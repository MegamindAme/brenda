<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Brenda.App.ViewModels"
             xmlns:models="using:Brenda.Core.Models"
             x:Class="Brenda.App.Views.VersionsView"
             x:DataType="vm:VersionsViewModel"
             x:Name="Root">

    <DockPanel Margin="24">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Blender Versions" Classes="h1"/>
                <TextBlock Text="Install official builds or register existing installations." Classes="muted"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Add Existing..." Command="{Binding AddExistingCommand}" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- Update banner -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0,0,0,12"
                IsVisible="{Binding UpdateBanner, Converter={x:Static ObjectConverters.IsNotNull}}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="🔔"/>
                <TextBlock Text="{Binding UpdateBanner}"/>
            </StackPanel>
        </Border>

        <!-- Install progress -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0,0,0,12" IsVisible="{Binding IsInstalling}">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding InstallStatus}"/>
                <ProgressBar Value="{Binding InstallProgress}" Maximum="100"/>
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,*">

            <!-- Installed -->
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock DockPanel.Dock="Top" Text="Installed" Classes="h2" Margin="0,0,0,8"/>
                <StackPanel IsVisible="{Binding !Installed.Count}" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="No Blender versions yet." HorizontalAlignment="Center" Classes="muted"/>
                    <TextBlock Text="Install one from the list or add an existing installation."
                               HorizontalAlignment="Center" Classes="muted"/>
                </StackPanel>
                <ScrollViewer IsVisible="{Binding Installed.Count}">
                    <ItemsControl ItemsSource="{Binding Installed}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:BlenderVersion">
                                <Border Classes="card" Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Version, StringFormat='Blender {0}'}" FontWeight="SemiBold"/>
                                                <TextBlock Text="★ default" Classes="muted" IsVisible="{Binding IsDefault}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ExecutablePath}" Classes="muted" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Button Content="Launch"
                                                    Classes="accent"
                                                    Command="{Binding #Root.((vm:VersionsViewModel)DataContext).LaunchCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Default"
                                                    Command="{Binding #Root.((vm:VersionsViewModel)DataContext).SetDefaultCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Remove"
                                                    Command="{Binding #Root.((vm:VersionsViewModel)DataContext).RemoveCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- Available -->
            <DockPanel Grid.Column="1" Margin="8,0,0,0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <TextBlock Text="Available Downloads" Classes="h2"/>
                    <ProgressBar IsIndeterminate="True" Width="80" IsVisible="{Binding IsBusy}"/>
                </StackPanel>
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Available}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:BlenderRelease">
                                <Border Classes="card" Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Version, StringFormat='Blender {0}'}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Channel}" Classes="muted"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding FileName}" Classes="muted" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Install"
                                                VerticalAlignment="Center"
                                                Command="{Binding #Root.((vm:VersionsViewModel)DataContext).InstallCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
