<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Brenda.App.ViewModels"
             x:Class="Brenda.App.Views.CleanupView"
             x:DataType="vm:CleanupViewModel">

    <DockPanel Margin="24">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Memory Cleaning" Classes="h1"/>
                <TextBlock Text="Find and remove .blend1 backups and temporary files." Classes="muted"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Scan Projects" Classes="accent"
                    Command="{Binding ScanProjectsCommand}" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Scan Folder..." Command="{Binding ScanFolderCommand}"/>
        </Grid>

        <!-- Status -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="80" IsVisible="{Binding IsScanning}"/>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                    Margin="0,12,0,0" HorizontalAlignment="Right"
                    IsVisible="{Binding Items.Count}">
            <Button Content="Select All" Command="{Binding SelectAllCommand}"/>
            <Button Content="Select None" Command="{Binding SelectNoneCommand}"/>
            <Button Content="Delete Selected" Classes="accent" Command="{Binding DeleteSelectedCommand}"/>
        </StackPanel>

        <!-- Results -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CleanupItemViewModel">
                        <Border Classes="card" Margin="0,0,0,6" Padding="12,8">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Path}" Margin="12,0,0,0"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{Binding KindText}" Classes="muted" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding SizeText}" VerticalAlignment="Center" MinWidth="70"
                                           TextAlignment="Right" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
